# ─────────────────────────────────────────────────────────────────────────────
# Medusa v2 environment variables
# Copy to .env and fill in real values. Never commit .env.
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=development

# ── Database ─────────────────────────────────────────────────────────────────
# Local dev:  postgresql://postgres:password@localhost:5432/randall_design
# Railway:    Automatically injected when the Postgres plugin is linked.
DATABASE_URL=postgresql://postgres:password@localhost:5432/randall_design

# ── Redis ────────────────────────────────────────────────────────────────────
# Local dev:  redis://localhost:6379
# Railway:    Automatically injected when the Redis plugin is linked.
REDIS_URL=redis://localhost:6379

# ── Security – generate with: openssl rand -base64 48 ────────────────────────
JWT_SECRET=change_me_use_openssl_rand
COOKIE_SECRET=change_me_use_openssl_rand

# ── Public backend URL (set to your Railway service URL after first deploy) ──
MEDUSA_BACKEND_URL=http://localhost:9000

# ── CORS origins (comma-separated, no trailing slash) ────────────────────────
# Production example: https://your-store.netlify.app
STORE_CORS=http://localhost:4321
# Medusa admin dashboard origin
ADMIN_CORS=http://localhost:9000
# Auth endpoints CORS (usually same as storefront + admin)
AUTH_CORS=http://localhost:4321,http://localhost:9000

# ── Worker mode ──────────────────────────────────────────────────────────────
# 'shared' runs API + workers in one process (Railway free tier / staging)
# 'server' / 'worker' split for dedicated Railway services at scale
MEDUSA_WORKER_MODE=shared

# ── Payment providers (uncomment when adding a provider) ─────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# CYBERSOURCE_MERCHANT_ID=...
# CYBERSOURCE_API_KEY_ID=...
# CYBERSOURCE_SECRET_KEY=...
