# ─────────────────────────────────────────────────────────────────────────────
# Astro storefront environment variables
# PUBLIC_ prefix exposes variables to the browser bundle.
# Copy to .env and fill in real values. Never commit .env.
# ─────────────────────────────────────────────────────────────────────────────

# Medusa backend URL
# Local dev:   http://localhost:9000
# Production:  https://your-service.up.railway.app
PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000

# Medusa publishable API key
# Create one in the Medusa Admin → Settings → API Keys → Create publishable key
PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_
