---
interface Props {
  title: string
}

const { title } = Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Randall Design Store" />
    <title>{title} | Randall Design</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
  </head>
  <body>
    <header>
      <nav>
        <a href="/" class="wordmark">Randall Design</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <p>&copy; {new Date().getFullYear()} Randall Design</p>
    </footer>
  </body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: system-ui, -apple-system, sans-serif;
    background: #fff;
    color: #111;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
  }

  header {
    border-bottom: 1px solid #e5e5e5;
    padding: 1rem 2rem;
  }

  nav {
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .wordmark {
    font-size: 1.125rem;
    font-weight: 600;
    text-decoration: none;
    color: inherit;
    letter-spacing: -0.02em;
  }

  main {
    flex: 1;
    max-width: 1280px;
    margin: 0 auto;
    padding: 2rem;
    width: 100%;
  }

  footer {
    border-top: 1px solid #e5e5e5;
    padding: 1rem 2rem;
    text-align: center;
    font-size: 0.875rem;
    color: #666;
  }
</style>
